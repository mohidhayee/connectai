# Copy this file to ".env" and fill in your real keys.
# The .env file is gitignored and will NEVER be committed.
#
# You only need ONE key to start. Groq is free and is the default — get that
# first and you can run everything at no cost.

# Groq (free, default) — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (cheap; needs billing in the EU) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (add later) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (add later) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
