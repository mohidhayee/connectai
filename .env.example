# Copy this file to ".env" and fill in your real keys.
# The .env file is gitignored and will NEVER be committed.
#
# All keys are OPTIONAL. You only need a key for the providers you actually use.
# Groq is free and is the default — get that one first and you can run the whole
# app at no cost. (In the web app you can also paste keys directly, per session.)

# Groq (free, default) — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (cheap; needs billing in the EU) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (add later) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic / Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Perplexity (live web search) — https://www.perplexity.ai/settings/api
PERPLEXITYAI_API_KEY=
